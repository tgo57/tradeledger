@page "/import"

@using MudBlazor
@using TradeLedger.Web.Services
@inject SchwabCsvImportService SchwabImport
@inject TastyTradeImporter TastyImport
@inject ClearAccountService ClearAccount
@inject ImportHistoryService ImportHistory
@inject SchwabOAuthService SchwabOAuth
@inject SchwabSyncService SchwabSync
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject TastyTradeApiService TastyApi


<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudText Typo="Typo.h5" Class="mb-4">Import Trades</MudText>

    <MudGrid>

        @* ── Schwab Card ─────────────────────────────────────────── *@
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="1" Style="height:100%;">
                <MudStack Spacing="3">

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">Charles Schwab</MudText>
                    </MudStack>

                    <MudDivider />

                    <MudSelect T="string" @bind-Value="_schwabAccount" Label="Account" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Schwab1")">Schwab1</MudSelectItem>
                        <MudSelectItem Value="@("Schwab2")">Schwab2</MudSelectItem>
                    </MudSelect>

                    <MudText Typo="Typo.subtitle2">Upload CSV Export</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Download from Schwab: Accounts → History → Export
                    </MudText>

                    <InputFile id="schwabFile" OnChange="OnSchwabFileSelected" accept=".csv" style="display:none;" />
                    <MudButton HtmlTag="label" Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.UploadFile"
                               for="schwabFile" FullWidth="true">
                        @(_schwabFileName ?? "Choose CSV File")
                    </MudButton>

                    @if (_schwabFile != null)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                   OnClick="ImportSchwab" Disabled="_schwabImporting" FullWidth="true">
                            @if (_schwabImporting)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Importing...</span>
                            }
                            else
                            {

                                <span>Import Schwab CSV</span>
                            }
                        </MudButton>
                    }

                    @if (_schwabResult != null)
                    {
                        <MudAlert Severity="@(_schwabResult.Errors.Any() ? Severity.Warning : Severity.Success)">
                            ✅ @_schwabResult.Inserted inserted &nbsp;|&nbsp; ⏭ @_schwabResult.Skipped skipped
                            @if (_schwabResult.Errors.Any())
                            {
                                <br />
                                @foreach (var e in _schwabResult.Errors.Take(5))
                                {
                                    <div>⚠ @e</div>
                                }
                            }
                        </MudAlert>
                    }

                    <MudDivider />
                    <MudText Typo="Typo.subtitle2">Auto-Sync (OAuth)</MudText>

                    @if (SchwabOAuth.IsConnected)
                    {
                        <MudAlert Severity="Severity.Success">
                            ✅ Connected — expires in @SchwabOAuth.DaysUntilExpiry day(s).
                            Re-login required every 7 days.
                        </MudAlert>

                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Sync"
                                   OnClick="SyncSchwab" Disabled="_schwabSyncing" FullWidth="true">
                            @if (_schwabSyncing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Syncing...</span>
                            }
                            else
                            {

                                <span>Sync Now (Last 60 Days)</span>
                            }
                        </MudButton>

                        @if (_syncResult != null)
                        {
                            <MudAlert Severity="@(_syncResult.Errors.Any() ? Severity.Warning : Severity.Success)">
                                ✅ @_syncResult.Inserted inserted &nbsp;|&nbsp; ⏭ @_syncResult.Skipped skipped
                            </MudAlert>
                        }

                        <MudButton Variant="Variant.Text" Color="Color.Error"
                                   OnClick="DisconnectSchwab" FullWidth="true">
                            Disconnect
                        </MudButton>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Warning">
                            Not connected. Click below to authorize, then paste the callback URL.
                        </MudAlert>

                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.OpenInBrowser"
                                   OnClick="ConnectSchwab" FullWidth="true">
                            Step 1: Open Schwab Login
                        </MudButton>

                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            After logging in, you'll see an error page — that's OK.
                            Copy the full URL from the browser address bar and paste it below.
                        </MudText>

                        <MudTextField @bind-Value="_callbackUrl"
                                      Label="Step 2: Paste callback URL here"
                                      Variant="Variant.Outlined"
                                      Placeholder="https://...callback?code=..."
                                      FullWidth="true" />

                        @if (!string.IsNullOrWhiteSpace(_callbackUrl))
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.Check"
                                       OnClick="ExchangeCodeManually"
                                       Disabled="_exchanging"
                                       FullWidth="true">
                                @if (_exchanging)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Connecting...</span>
                                }
                                else
                                {

                                    <span>Step 3: Connect</span>
                                }
                            </MudButton>
                        }
                    }

                </MudStack>
            </MudPaper>
        </MudItem>

        @* ── TastyTrade Card ─────────────────────────────────────── *@
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="1" Style="height:100%;">
                <MudStack Spacing="3">

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.ShowChart" Color="Color.Secondary" />
                        <MudText Typo="Typo.h6">tastytrade</MudText>
                    </MudStack>

                    <MudDivider />

                    <MudSelect T="string" @bind-Value="_tastyAccount" Label="Account" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Tasty1")">Tasty1 (Individual)</MudSelectItem>
                        <MudSelectItem Value="@("Tasty2")">Tasty2</MudSelectItem>
                    </MudSelect>

                    @* ── CSV Upload ── *@
                    <MudText Typo="Typo.subtitle2">Upload Transaction History CSV</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Download from tastytrade: History → Transaction History → Export CSV
                    </MudText>

                    <InputFile id="tastyFile" OnChange="OnTastyFileSelected" accept=".csv" style="display:none;" />
                    <MudButton HtmlTag="label" Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.UploadFile"
                               for="tastyFile" FullWidth="true">
                        @(_tastyFileName ?? "Choose CSV File")
                    </MudButton>

                    @if (_tastyFile != null)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                   OnClick="ImportTasty" Disabled="_tastyImporting" FullWidth="true">
                            @if (_tastyImporting)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Importing...</span>
                            }
                            else
                            {
                                <span>Import tastytrade CSV</span>
                            }
                        </MudButton>
                    }

                    @if (_tastyResult != null)
                    {
                        <MudAlert Severity="@(_tastyResult.Errors.Any() ? Severity.Warning : Severity.Success)">
                            @_tastyResult.Inserted inserted &nbsp;|&nbsp; @_tastyResult.Skipped skipped
                            @if (_tastyResult.Errors.Any())
                            {
                                <br />
                                @foreach (var e in _tastyResult.Errors.Take(5))
                                {
                                    <div>@e</div>
                                }
                            }
                        </MudAlert>
                    }

                    @* ── API Auto-Sync ── *@
                    <MudDivider />
                    <MudText Typo="Typo.subtitle2">Auto-Sync (API)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Fetches option trades directly from tastytrade. Duplicates are skipped automatically.
                    </MudText>

                    @* Quick-select preset buttons *@
                    <MudStack Row="true" Spacing="1" Justify="Justify.FlexStart">
                        @foreach (var preset in _syncPresets)
                        {
                            <MudButton Variant="@(_tastySyncDays == preset.Days ? Variant.Filled : Variant.Outlined)"
                                       Color="Color.Secondary"
                                       Size="Size.Small"
                                       OnClick="@(() => ApplySyncPreset(preset.Days))">
                                @preset.Label
                            </MudButton>
                        }
                    </MudStack>

                    @* Custom date range *@
                    <MudStack Row="true" Spacing="2">
                        <MudDatePicker Label="From"
                                       @bind-Date="_tastySyncFrom"
                                       Variant="Variant.Outlined"
                                       DateFormat="MM/dd/yyyy"
                                       MaxDate="DateTime.Today"
                                       Style="width:100%" />
                        <MudDatePicker Label="To"
                                       @bind-Date="_tastySyncTo"
                                       Variant="Variant.Outlined"
                                       DateFormat="MM/dd/yyyy"
                                       MaxDate="DateTime.Today"
                                       Style="width:100%" />
                    </MudStack>

                    <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Sync"
                               OnClick="SyncTasty" Disabled="_tastySyncing" FullWidth="true">
                        @if (_tastySyncing)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Syncing...</span>
                        }
                        else
                        {
                            <span>Sync @(_tastySyncDays > 0 ? $"Last {_tastySyncDays} Days" : "Selected Range")</span>
                        }
                    </MudButton>

                    @if (_tastySyncResult != null)
                    {
                        <MudAlert Severity="@(_tastySyncResult.Errors.Any() ? Severity.Warning : Severity.Success)">
                            @_tastySyncResult.Inserted inserted &nbsp;|&nbsp; @_tastySyncResult.Skipped skipped
                            @if (_tastySyncResult.Errors.Any())
                            {
                                <br />
                                @foreach (var e in _tastySyncResult.Errors.Take(5))
                                {
                                    <div>@e</div>
                                }
                            }
                        </MudAlert>
                    }

                </MudStack>
            </MudPaper>
        </MudItem>


    </MudGrid>

    @* ── Clear Account Data ───────────────────────────────────────── *@
    <MudPaper Class="pa-4 mt-4" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.DeleteSweep" Color="Color.Error" />
            <MudText Typo="Typo.h6">Clear Account Data</MudText>
        </MudStack>
        <MudDivider Class="mb-3" />
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
            Permanently deletes all trade groups and executions for the selected account.
        </MudText>

        <MudGrid>
            <MudItem xs="12" md="4">
                <MudSelect T="string" @bind-Value="_clearBroker" Label="Broker" Variant="Variant.Outlined">
                    <MudSelectItem Value="@("Schwab")">Schwab</MudSelectItem>
                    <MudSelectItem Value="@("TastyTrade")">tastytrade</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="string" @bind-Value="_clearAccount" Label="Account" Variant="Variant.Outlined">
                    @if (_clearBroker == "Schwab")
                    {
                        <MudSelectItem Value="@("Schwab1")">Schwab1</MudSelectItem>
                        <MudSelectItem Value="@("Schwab2")">Schwab2</MudSelectItem>
                    }
                    else
                    {
                        <MudSelectItem Value="@("Tasty1")">Tasty1</MudSelectItem>
                        <MudSelectItem Value="@("Tasty2")">Tasty2</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4" Class="d-flex align-center">
                @if (!_confirmClear)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.DeleteForever"
                               OnClick="@(() => _confirmClear = true)" FullWidth="true">
                        Clear @_clearAccount
                    </MudButton>
                }
                else
                {
                    <MudStack Row="true" Spacing="1" Style="width:100%">
                        <MudButton Variant="Variant.Filled" Color="Color.Error"
                                   OnClick="DoClear" Disabled="_clearing" FullWidth="true">
                            @if (_clearing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Clearing...</span>
                            }
                            else
                            {

                                <span>Yes, Delete All</span>
                            }
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   OnClick="@(() => _confirmClear = false)" FullWidth="true">
                            Cancel
                        </MudButton>
                    </MudStack>
                }
            </MudItem>
        </MudGrid>

        @if (_clearResult != null)
        {
            <MudAlert Severity="Severity.Success" Class="mt-3">
                Cleared @_clearResult.GroupsDeleted trade groups and
                @_clearResult.ExecutionsDeleted executions from @_clearAccount.
            </MudAlert>
        }
    </MudPaper>

    @* ── Import History ───────────────────────────────────────────── *@
    <MudPaper Class="pa-4 mt-4" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6">Import History</MudText>
            <MudSpacer />
            @if (ImportHistory.History.Any())
            {
                <MudButton Size="Size.Small" Variant="Variant.Text"
                           OnClick="@(() => { ImportHistory.Clear(); StateHasChanged(); })">
                    Clear
                </MudButton>
            }
        </MudStack>
        <MudDivider Class="mb-3" />

        @if (!ImportHistory.History.Any())
        {
            <MudText Color="Color.Secondary">No imports yet.</MudText>
        }
        else
        {
            <MudTable Items="ImportHistory.History" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Time</MudTh>
                    <MudTh>Broker</MudTh>
                    <MudTh>Account</MudTh>
                    <MudTh>File</MudTh>
                    <MudTh>Inserted</MudTh>
                    <MudTh>Skipped</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Time.ToString("yyyy-MM-dd HH:mm:ss")</MudTd>
                    <MudTd>@context.Broker</MudTd>
                    <MudTd>@context.Account</MudTd>
                    <MudTd Class="tl-ellipsis" Style="max-width:200px;">@context.FileName</MudTd>
                    <MudTd>@context.Inserted</MudTd>
                    <MudTd>@context.Skipped</MudTd>
                    <MudTd>
                        @if (context.Errors.Any())
                        {
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">
                                @context.Errors.Count warning(s)
                            </MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">OK</MudChip>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

</MudContainer>

@code {
    private string _schwabAccount = "Schwab1";
    private IBrowserFile? _schwabFile;
    private string? _schwabFileName;
    private bool _schwabImporting;
    private SchwabCsvImportService.ImportResult? _schwabResult;

    private bool _schwabSyncing;
    private SchwabSyncService.SyncResult? _syncResult;

    private string _callbackUrl = "";
    private bool _exchanging;

    private string _tastyAccount = "Tasty1";
    private IBrowserFile? _tastyFile;
    private string? _tastyFileName;
    private bool _tastyImporting;
    private TastyTradeImporter.ImportResult? _tastyResult;

    private string _clearBroker = "TastyTrade";
    private string _clearAccount = "Tasty1";
    private bool _confirmClear;
    private bool _clearing;
    private ClearAccountService.ClearResult? _clearResult;

    private bool _tastySyncing;
    private TastyTradeImporter.ImportResult? _tastySyncResult;

    // Date range for sync
    private DateTime? _tastySyncFrom = DateTime.Today.AddDays(-30);
    private DateTime? _tastySyncTo = DateTime.Today;
    private int _tastySyncDays = 30; // tracks which preset is active (0 = custom)

    // Preset options shown as quick-select buttons
    private record SyncPreset(string Label, int Days);
    private readonly List<SyncPreset> _syncPresets =
    [
        new("30 Days",  30),
        new("60 Days",  60),
        new("90 Days",  90),
        new("6 Months", 180),
        new("1 Year",   365),
    ];

    // When a preset button is clicked, update dates and track active preset
    private void ApplySyncPreset(int days)
    {
        _tastySyncDays = days;
        _tastySyncTo = DateTime.Today;
        _tastySyncFrom = DateTime.Today.AddDays(-days);
    }

    // When the user manually edits a date picker, clear the active preset
    private void OnSyncFromChanged(DateTime? value)
    {
        _tastySyncFrom = value;
        _tastySyncDays = 0; // custom range
    }

    private void OnSyncToChanged(DateTime? value)
    {
        _tastySyncTo = value;
        _tastySyncDays = 0; // custom range
    }


    // ── Schwab OAuth ──────────────────────────────────────────────
    private void ConnectSchwab()
    {
        var url = SchwabOAuth.BuildAuthorizationUrl();
        Nav.NavigateTo(url, forceLoad: true);
    }

    private void DisconnectSchwab()
    {
        SchwabOAuth.Disconnect();
        Snackbar.Add("Schwab disconnected.", Severity.Info);
        StateHasChanged();
    }

    private async Task ExchangeCodeManually()
    {
        if (string.IsNullOrWhiteSpace(_callbackUrl)) return;
        _exchanging = true;
        try
        {
            // Extract code from pasted URL
            var uri = new Uri(_callbackUrl);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            var code = query["code"];

            if (string.IsNullOrWhiteSpace(code))
            {
                Snackbar.Add("No code found in URL. Make sure you pasted the full callback URL.", Severity.Error);
                return;
            }

            var (success, error) = await SchwabOAuth.ExchangeCodeForTokensAsync(code);
            if (success)
            {
                _callbackUrl = "";
                Snackbar.Add("✅ Schwab connected successfully!", Severity.Success);
                StateHasChanged();
            }
            else
            {
                Snackbar.Add($"Token exchange failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally { _exchanging = false; }
    }

    private async Task SyncSchwab()
    {
        _schwabSyncing = true;
        _syncResult = null;
        try
        {
            var accounts = await SchwabSync.GetAccountsAsync();
            var acct = accounts.FirstOrDefault();
            if (acct.Number == null)
            {
                Snackbar.Add("No Schwab accounts found. Try reconnecting.", Severity.Warning);
                return;
            }
            _syncResult = await SchwabSync.SyncAsync(acct.Number, _schwabAccount);
            ImportHistory.Add(new ImportHistoryService.HistoryEntry(
                DateTime.Now, "Schwab", _schwabAccount, "api-sync",
                _syncResult.Inserted, _syncResult.Skipped, _syncResult.Errors));
            Snackbar.Add($"Sync complete: {_syncResult.Inserted} new trades", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error);
        }
        finally { _schwabSyncing = false; }
    }

    // ── Schwab CSV ────────────────────────────────────────────────
    private void OnSchwabFileSelected(InputFileChangeEventArgs e)
    {
        _schwabFile = e.File; _schwabFileName = e.File.Name; _schwabResult = null;
    }

    private async Task ImportSchwab()
    {
        if (_schwabFile == null) return;
        _schwabImporting = true; _schwabResult = null;
        try
        {
            await using var stream = _schwabFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            _schwabResult = await SchwabImport.ImportAsync(stream, "Schwab", _schwabAccount, _schwabFileName ?? "upload.csv");
            ImportHistory.Add(new ImportHistoryService.HistoryEntry(
                DateTime.Now, "Schwab", _schwabAccount, _schwabFileName ?? "",
                _schwabResult.Inserted, _schwabResult.Skipped, _schwabResult.Errors));
            Snackbar.Add($"Schwab: {_schwabResult.Inserted} trades imported", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Import failed: {ex.Message}", Severity.Error); }
        finally { _schwabImporting = false; }
    }

    // ── TastyTrade ────────────────────────────────────────────────
    private void OnTastyFileSelected(InputFileChangeEventArgs e)
    {
        _tastyFile = e.File; _tastyFileName = e.File.Name; _tastyResult = null;
    }

    private async Task ImportTasty()
    {
        if (_tastyFile == null) return;
        _tastyImporting = true; _tastyResult = null;
        try
        {
            await using var stream = _tastyFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            _tastyResult = await TastyImport.ImportAsync(stream, _tastyAccount);
            ImportHistory.Add(new ImportHistoryService.HistoryEntry(
                DateTime.Now, "tastytrade", _tastyAccount, _tastyFileName ?? "",
                _tastyResult.Inserted, _tastyResult.Skipped, _tastyResult.Errors));
            Snackbar.Add($"tastytrade: {_tastyResult.Inserted} trades imported", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Import failed: {ex.Message}", Severity.Error); }
        finally { _tastyImporting = false; }
    }

    // ── Clear ─────────────────────────────────────────────────────
    private async Task DoClear()
    {
        _clearing = true; _clearResult = null;
        try
        {
            _clearResult = await ClearAccount.ClearAsync(_clearBroker, _clearAccount);
            _confirmClear = false;
            Snackbar.Add($"Cleared {_clearResult.GroupsDeleted} trades from {_clearAccount}", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Clear failed: {ex.Message}", Severity.Error); }
        finally { _clearing = false; }
    }

    private async Task SyncTasty()
    {
        if (_tastySyncFrom == null || _tastySyncTo == null)
        {
            Snackbar.Add("Please select a date range.", Severity.Warning);
            return;
        }

        _tastySyncing = true;
        _tastySyncResult = null;

        try
        {
            var sessionToken = await TastyApi.GetSessionTokenAsync();
            var accountNumber = "5WY36662"; // or pull from config: Configuration["TastyTrade:AccountNumber"]

            var executions = await TastyApi.GetOptionExecutionsAsync(
                accountNumber,
                sessionToken,
                since: _tastySyncFrom.Value);

            // Client-side trim to the To date (API only supports start date filtering)
            executions = executions
                .Where(e => e.ExecutedAt.Date <= _tastySyncTo.Value.Date)
                .ToList();

            _tastySyncResult = await TastyImport.ImportFromExecutionsAsync(executions, _tastyAccount);

            ImportHistory.Add(new ImportHistoryService.HistoryEntry(
                DateTime.Now, "tastytrade", _tastyAccount,
                $"api-sync {_tastySyncFrom:MM/dd/yy}–{_tastySyncTo:MM/dd/yy}",
                _tastySyncResult.Inserted, _tastySyncResult.Skipped, _tastySyncResult.Errors));

            Snackbar.Add($"tastytrade sync: {_tastySyncResult.Inserted} new trades", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error);
        }
        finally { _tastySyncing = false; }
    }

}
