@page "/dashboard"
@implements IDisposable

@using MudBlazor
@using TradeLedger.Web.Models
@using TradeLedger.Web.Services
@inject TradesReadService TradesRead
@inject DashboardService Svc
@inject TradeLedger.Web.Services.AppStateService AppState

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4">

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
            Account: <b>@AppState.Account</b>
        </MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="Load">Refresh</MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Class="mt-3" />
    }
    else if (_vm is not null)
    {
        <div class="tl-kpi-strip mt-3">

            <div class="tl-kpi-item">
                <KpiCard Title="Acc. Return $"
                         Value="@FilteredGrossReturn.ToString("0.00")"
                         AccentClass="@(FilteredGrossReturn >= 0 ? "accent-green" : "accent-red")"
                         Trend="@SparkTrend(FilteredSparkGross)"
                         ShowTrend="true"
                         ShowSparkline="true"
                         Sparkline="@FilteredSparkGross" />
            </div>

            <div class="tl-kpi-item">
                <KpiCard Title="Net P/L"
                         Value="@FilteredNetPL.ToString("0.00")"
                         AccentClass="@(FilteredNetPL >= 0 ? "accent-green" : "accent-red")"
                         Trend="@SparkTrend(FilteredSparkNetPl)"
                         ShowTrend="true"
                         ShowSparkline="true"
                         Sparkline="@FilteredSparkNetPl" />
            </div>

            <div class="tl-kpi-item">
                <KpiCard Title="Profit Factor"
                         Value="@(FilteredProfitFactor == 0m ? "—" : FilteredProfitFactor >= 99m ? "Max" : FilteredProfitFactor.ToString("0.00"))"
                         AccentClass="@(
                         FilteredProfitFactor == 0m ? "accent-gray" :
                         FilteredProfitFactor >= 1.5m ? "accent-green" :
                         FilteredProfitFactor >= 0.5m ? "accent-gray" :
                         "accent-red"
                                                  )"
                     ShowSparkline="true"
                     Trend="@SparkTrend(FilteredSparkPf)"
                     ShowTrend="true"
                     Sparkline="@FilteredSparkPf" />
        </div>

            <div class="tl-kpi-item">
                <KpiCard Title="Win Rate"
                         Value="@($"{FilteredWinRate * 100m:0.0}%")"
                         AccentClass="@(
                                                  FilteredWinRate >= 0.60m ? "accent-green" :
                                                  FilteredWinRate >= 0.50m ? "accent-gray" :
                                                  "accent-red"
                                                  )"
                     Subtext="@($"{Math.Round(FilteredDonutWinLoss[0]):0}W / {Math.Round(FilteredDonutWinLoss[1]):0}L")"
                     Trend="@WinRateTrend()"
                     ShowDonut="true"
                     DonutParts="@FilteredDonutWinLoss"
                     DonutLabels="@(new[] { "Win", "Loss" })" />
        </div>

            <div class="tl-kpi-item">
                <KpiCard Title="Avg P/L"
                         Value="@FilteredAvgPL.ToString("0.00")"
                         AccentClass="@(FilteredAvgPL >= 0 ? "accent-green" : "accent-red")" />
            </div>

            <div class="tl-kpi-item">
                <KpiCard Title="Max Drawdown"
                         Value="@FilteredMaxDrawdown.ToString("0.00")"
                         AccentClass="accent-red" />
            </div>

            <div class="tl-kpi-item">
                <KpiCard Title="Trades"
                         Value="@FilteredTradeCount.ToString()"
                         AccentClass="accent-blue" />
            </div>

        </div>

        <MudGrid Class="mt-3">
            <MudItem xs="12" md="9">
                <MudPaper Class="pa-3">
                    <MudText Typo="Typo.subtitle1" Style="font-weight:700;">Trades</MudText>

                    <div class="tl-filter-bar mt-2">

                        <MudSelect T="string" Value="@_filterRange"
                                   ValueChanged="@((string v) => { _filterRange = v; StateHasChanged(); })"
                                   Variant="Variant.Outlined" 
                                   Class="tl-filter-chip" Label="Date"
                                   AnchorOrigin="Origin.BottomLeft">
                            <MudSelectItem Value="@("all")">All Time</MudSelectItem>
                            <MudSelectItem Value="@("ytd")">YTD</MudSelectItem>
                            <MudSelectItem Value="@("30d")">Last 30 Days</MudSelectItem>
                            <MudSelectItem Value="@("90d")">Last 90 Days</MudSelectItem>
                            <MudSelectItem Value="@("6m")">Last 6 Months</MudSelectItem>
                            <MudSelectItem Value="@("1y")">Last Year</MudSelectItem>
                            <MudSelectItem Value="@("custom")">Custom...</MudSelectItem>
                        </MudSelect>

                    @if (_filterRange == "custom")
                        {
                            <MudDatePicker @bind-Date="_customStart"
                                           Placeholder="From"
                                           Variant="Variant.Outlined"
                                           Class="tl-filter-chip"
                                           DateFormat="yyyy-MM-dd"
                                           Editable="true" />

                            <MudDatePicker @bind-Date="_customEnd"
                                           Placeholder="To"
                                           Variant="Variant.Outlined"
                                           Class="tl-filter-chip"
                                           DateFormat="yyyy-MM-dd"
                                           Editable="true" />
                        }

                        <MudSelect T="string" @bind-Value="_filterStatus"
                                   Variant="Variant.Outlined" 
                                   Class="tl-filter-chip" Label="Status"
                                   AnchorOrigin="Origin.BottomLeft">
                            <MudSelectItem Value="@("all")">All</MudSelectItem>
                            <MudSelectItem Value="@("WIN")">Win</MudSelectItem>
                            <MudSelectItem Value="@("LOSS")">Loss</MudSelectItem>
                            <MudSelectItem Value="@("OPEN")">Open</MudSelectItem>
                        </MudSelect>

                        <MudSelect T="string" @bind-Value="_filterSymbol"
                                   Variant="Variant.Outlined" 
                                   Class="tl-filter-chip" Label="Symbol"
                                   AnchorOrigin="Origin.BottomLeft">
                            <MudSelectItem Value="@("all")">All</MudSelectItem>
                            @foreach (var sym in _availableSymbols)
                            {
                                <MudSelectItem Value="@sym">@sym</MudSelectItem>
                            }
                        </MudSelect>

                        <MudSelect T="string" @bind-Value="_filterSide"
                                   Variant="Variant.Outlined" 
                                   Class="tl-filter-chip" Label="Side"
                                   AnchorOrigin="Origin.BottomLeft">
                            <MudSelectItem Value="@("all")">All</MudSelectItem>
                            <MudSelectItem Value="@("Put")">Put</MudSelectItem>
                            <MudSelectItem Value="@("Call")">Call</MudSelectItem>
                        </MudSelect>

                        <MudSelect T="string" @bind-Value="_filterReturn"
                                   Variant="Variant.Outlined" 
                                   Class="tl-filter-chip" Label="Return $"
                                   AnchorOrigin="Origin.BottomLeft">
                            <MudSelectItem Value="@("all")">All</MudSelectItem>
                            <MudSelectItem Value="@("pos")">Positive</MudSelectItem>
                            <MudSelectItem Value="@("neg")">Negative</MudSelectItem>
                            <MudSelectItem Value="@("0-500")">$0 – $500</MudSelectItem>
                            <MudSelectItem Value="@("500-1000")">$500 – $1,000</MudSelectItem>
                            <MudSelectItem Value="@("1000+")">$1,000+</MudSelectItem>
                        </MudSelect>

                        @if (AnyFilterActive)
                        {
                            <MudButton Variant="Variant.Text" Size="Size.Small"
                                       Class="tl-filter-clear" OnClick="ClearFilters">
                                ✕ Clear
                            </MudButton>
                        }

                    </div>

                    <div class="tl-table-scroll">
                        <MudTable T="TradeRow" Items="FilteredTrades"
                                  Class="tl-trades-table"
                                  Dense="true" Hover="true" Striped="true"
                                  RowClickEvent="_rowClickCb">

                            <HeaderContent>
                                <MudTh></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<TradeRow, object>(x => x.CloseDate == null ? 0 : x.NetPL > 0 ? 1 : -1)">Status</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<TradeRow, object>(x => x.OpenDate)">Open</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<TradeRow, object>(x => x.CloseDate)">Close</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<TradeRow, object>(x => x.Expiration)">Exp</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<TradeRow, object>(x => x.Underlying)">Symbol</MudTableSortLabel></MudTh>
                                <MudTh Class="tl-col-putcall"><MudTableSortLabel SortBy="new Func<TradeRow, object>(x => x.Right)">Put/Call</MudTableSortLabel></MudTh>
                                <MudTh Class="tl-col-strikes"><MudTableSortLabel SortBy="new Func<TradeRow, object>(x => x.ShortStrike)">Strikes</MudTableSortLabel></MudTh>
                                <MudTh Class="tl-col-fees"><MudTableSortLabel SortBy="new Func<TradeRow, object>(x => x.TotalFees)">Fees</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<TradeRow, object>(x => x.ReturnGross)">Return $</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<TradeRow, object>(x => x.NetReturnPct)">Net Return %</MudTableSortLabel></MudTh>
                            </HeaderContent>

                            <RowTemplate>
                                <MudTd>
                                    <MudIconButton Size="Size.Small"
                                                   Icon="@(_expanded.Contains(context.Id) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                                   OnClick="@(async () => await ToggleExecAsync(context.Id))" />
                                </MudTd>
                                <MudTd>
                                    @{
                                        var s = Status(context);
                                        var chipClass = $"tl-chip tl-chip-{s.ToLowerInvariant()}";
                                    }
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                             Color="Color.Default" Class="@chipClass">@s</MudChip>
                                </MudTd>
                                <MudTd Class="tl-nowrap">
                                    <MudText Typo="Typo.body2" Class="tl-date">@context.OpenDate.ToString("yyyy-MM-dd")</MudText>
                                </MudTd>
                                <MudTd Class="tl-nowrap">
                                    <MudText Typo="Typo.body2" Class="tl-date">
                                        @(context.CloseDate is null ? "—" : context.CloseDate.Value.ToString("yyyy-MM-dd"))
                                    </MudText>
                                </MudTd>
                                <MudTd Class="tl-nowrap">
                                    <MudText Typo="Typo.body2" Class="tl-date">@context.Expiration.ToString("yyyy-MM-dd")</MudText>
                                </MudTd>
                                <MudTd>@context.Underlying</MudTd>
                                <MudTd Class="tl-col-putcall">@context.Right</MudTd>
                                <MudTd Class="tl-col-strikes">
                                    <MudText Typo="Typo.body2" Class="tl-nowrap">
                                        <b>@context.ShortStrike.ToString("0")</b>/@context.LongStrike.ToString("0")
                                    </MudText>
                                </MudTd>
                                <MudTd Class="tl-col-fees" Style="text-align:right">@context.TotalFees.ToString("0.00")</MudTd>
                                <MudTd Style="text-align:right">
                                    <MudText Typo="Typo.body2" Class="@(context.ReturnGross >= 0 ? "tl-pos" : "tl-neg")">
                                        @context.ReturnGross.ToString("0.00")
                                    </MudText>
                                </MudTd>
                                <MudTd Style="text-align:right">
                                    @if (context.NetReturnPct is { } pct)
                                    {
                                        <MudText Typo="Typo.body2" Class="@(pct >= 0 ? "tl-pos" : "tl-neg")">
                                            @($"{pct:0.00}%")
                                        </MudText>
                                    }
                                    else
                                    {
                                        <MudText Class="tl-date">—</MudText>
                                    }
                                </MudTd>
                            </RowTemplate>

                            <ChildRowContent>
                                @if (_expanded.Contains(context.Id))
                                {
                                    <MudTd ColSpan="11" Class="pl-6 pr-6 pb-4 tl-childrow tl-detail-cell">
                                        @if (_execLoading.Contains(context.Id))
                                        {
                                            <MudProgressLinear Indeterminate="true" />
                                        }
                                        else if (_execCache.TryGetValue(context.Id, out var execs))
                                        {
                                            <ExecutionBreakdown Executions="execs" />
                                        }
                                        else
                                        {
                                            <MudText>No executions found.</MudText>
                                        }
                                    </MudTd>
                                }
                            </ChildRowContent>

                        </MudTable>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="3">
                <MudStack Spacing="2">

                    <MudPaper Class="pa-3">
                        <MudText Typo="Typo.subtitle1" Class="tl-panel-title">Year</MudText>
                        <MudDivider Class="my-2" />
                        @{
                            var maxYear = _vm.ByYear.Any() ? (double)_vm.ByYear.Max(r => Math.Abs(r.Value)) : 1.0;
                            if (maxYear == 0) maxYear = 1;
                        }
                        @foreach (var r in _vm.ByYear)
                        {
                            <div class="tl-stat-row">
                                <span class="tl-stat-label">@r.Label</span>
                                <div class="tl-stat-bar-wrap">
                                    <div class="tl-stat-bar @(r.Value >= 0 ? "tl-stat-bar-pos" : "tl-stat-bar-neg")"
                                         style="width:@((Math.Abs((double)r.Value) / maxYear * 100).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%">
                                    </div>
                                </div>
                                <span class="tl-stat-value @(r.Value >= 0 ? "tl-pos" : "tl-neg")">
                                    $@r.Value.ToString("N0")
                                </span>
                            </div>
                        }
                    </MudPaper>

                    <MudPaper Class="pa-3">
                        <MudText Typo="Typo.subtitle1" Class="tl-panel-title">Monthly</MudText>
                        <MudDivider Class="my-2" />
                        @{
                            var recentMonths = _vm.ByMonth.TakeLast(12).ToList();
                            var maxMonth = recentMonths.Any() ? (double)recentMonths.Max(r => Math.Abs(r.Value)) : 1.0;
                            if (maxMonth == 0) maxMonth = 1;
                        }
                        @foreach (var r in recentMonths)
                        {
                            <div class="tl-stat-row">
                                <span class="tl-stat-label">@r.Label</span>
                                <div class="tl-stat-bar-wrap">
                                    <div class="tl-stat-bar @(r.Value >= 0 ? "tl-stat-bar-pos" : "tl-stat-bar-neg")"
                                         style="width:@((Math.Abs((double)r.Value) / maxMonth * 100).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%">
                                    </div>
                                </div>
                                <span class="tl-stat-value @(r.Value >= 0 ? "tl-pos" : "tl-neg")">
                                    $@r.Value.ToString("N0")
                                </span>
                            </div>
                        }
                    </MudPaper>

                    <MudPaper Class="pa-3">
                        <MudText Typo="Typo.subtitle1">DTE Buckets</MudText>
                        <MudDivider Class="my-2" />
                        @foreach (var r in _vm.ByDteBucket)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudText>@r.Bucket</MudText>
                                <MudSpacer />
                                <MudText>PF @(r.ProfitFactor >= 99m ? "Max" : r.ProfitFactor.ToString("0.00"))</MudText>
                            </MudStack>
                            <MudText Typo="Typo.caption">@($"{r.Trades} trades | {r.TotalPL:0.00} P/L | {r.MinDte}-{r.MaxDte} DTE")</MudText>
                            <MudDivider Class="my-2" />
                        }
                    </MudPaper>

                </MudStack>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private bool _loading;
    private DashboardVm? _vm;

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += OnAppStateChanged;
        await Load();
    }

    private async void OnAppStateChanged()
    {
        await Load();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppState.OnChange -= OnAppStateChanged;
    }

    private async Task Load()
    {
        _loading = true;
        try
        {
            _vm = await Svc.GetDashboard(AppState.Broker, AppState.Account, take: 200);
            BuildKpiCharts();
            BuildSymbolList();
        }
        finally { _loading = false; }
    }

    private EventCallback<TableRowClickEventArgs<TradeRow>> _rowClickCb;

    protected override void OnInitialized()
    {
        _rowClickCb = EventCallback.Factory.Create(this,
            new Action<TableRowClickEventArgs<TradeRow>>(args => _ = OpenDetailsAsync(args.Item)));
    }

    private static string Status(TradeRow g)
    {
        if (g.CloseDate is null) return "OPEN";
        if (g.NetPL > 0m) return "WIN";
        if (g.NetPL < 0m) return "LOSS";
        return "FLAT";
    }

    private readonly HashSet<long> _expanded = new();
    private readonly Dictionary<long, List<ExecutionRowDto>> _execCache = new();
    private readonly HashSet<long> _execLoading = new();

    private async Task ToggleExecAsync(long id)
    {
        if (_expanded.Contains(id)) { _expanded.Remove(id); return; }
        _expanded.Add(id);
        if (_execCache.ContainsKey(id)) return;
        _execLoading.Add(id);
        try { _execCache[id] = await TradesRead.GetExecutionsForGroupAsync(id); }
        finally { _execLoading.Remove(id); }
    }

    private TradeRow? _selectedTrade;

    private async Task OpenDetailsAsync(TradeRow? trade)
    {
        if (trade is null) return;
        _selectedTrade = trade;
        if (_execCache.ContainsKey(trade.Id)) return;
        _execLoading.Add(trade.Id);
        try { _execCache[trade.Id] = await TradesRead.GetExecutionsForGroupAsync(trade.Id); }
        finally { _execLoading.Remove(trade.Id); }
    }

    private double[] _sparkPf = Array.Empty<double>();
    private double[] _donutWinLoss = Array.Empty<double>();

    private void BuildKpiCharts()
    {
        if (_vm is null || _vm.Trades is null || _vm.Trades.Count == 0)
        {
            _sparkPf = Array.Empty<double>();
            _donutWinLoss = new double[] { 0, 0 };
            return;
        }
        var ordered = _vm.Trades.OrderBy(t => t.OpenDate).ToList();
        var closed = ordered.Where(t => t.CloseDate is not null).ToList();
        var wins = closed.Count(t => t.NetPL > 0m);
        var losses = closed.Count(t => t.NetPL < 0m);
        _donutWinLoss = new double[] { Math.Max(wins, 0.001), Math.Max(losses, 0.001) };
        _sparkPf = CumulativeProfitFactor(ordered).TakeLast(30).ToArray();
    }

    static IEnumerable<double> CumulativeProfitFactor(List<TradeRow> ordered)
    {
        var closed = ordered.Where(t => t.CloseDate is not null).ToList();
        if (closed.Count == 0) yield break;
        double gains = 0, losses = 0;
        foreach (var t in closed)
        {
            var pl = (double)t.NetPL;
            if (pl > 0) gains += pl; else if (pl < 0) losses += -pl;
            var pf = losses <= 0.000001 ? (gains > 0 ? 99 : 0) : gains / losses;
            yield return Math.Min(pf, 10);
        }
    }

    static IEnumerable<double> Cumulative(IEnumerable<double> xs)
    {
        double acc = 0;
        foreach (var x in xs) { acc += x; yield return acc; }
    }

    private int SparkTrend(double[] s)
    {
        if (s is null || s.Length < 2) return 0;
        return s[^1] > s[^2] ? 1 : s[^1] < s[^2] ? -1 : 0;
    }

    private int WinRateTrend()
    {
        var closed = FilteredTrades.Where(t => t.CloseDate is not null).OrderBy(t => t.CloseDate).ToList();
        if (closed.Count < 6) return 0;
        var last5 = closed.TakeLast(5).ToList();
        var prev5 = closed.Skip(Math.Max(0, closed.Count - 10)).Take(5).ToList();
        decimal WR(List<TradeRow> xs) { var w = xs.Count(t => t.NetPL > 0m); var n = w + xs.Count(t => t.NetPL < 0m); return n == 0 ? 0m : (decimal)w / n; }
        var r1 = WR(prev5); var r2 = WR(last5);
        return r2 > r1 ? 1 : r2 < r1 ? -1 : 0;
    }

    private string _filterRange = "all";
    private string _filterStatus = "all";
    private string _filterSymbol = "all";
    private string _filterSide = "all";
    private string _filterReturn = "all";
    private DateTime? _customStart;
    private DateTime? _customEnd;
    private List<string> _availableSymbols = new();

    private bool AnyFilterActive =>
        _filterRange != "all" || _filterStatus != "all" ||
        _filterSymbol != "all" || _filterSide != "all" || _filterReturn != "all";

    private void ClearFilters()
    {
        _filterRange = "all"; _filterStatus = "all";
        _filterSymbol = "all"; _filterSide = "all"; _filterReturn = "all";
        _customStart = null; _customEnd = null;
    }

    private void BuildSymbolList()
    {
        if (_vm?.Trades is null) return;
        _availableSymbols = _vm.Trades
            .Select(t => t.Underlying).Where(s => !string.IsNullOrWhiteSpace(s))
            .Distinct().OrderBy(s => s).ToList();
    }

    private List<TradeRow> FilteredTrades
    {
        get
        {
            if (_vm?.Trades is null) return new();
            var q = _vm.Trades.AsEnumerable();
            var now = DateTime.Today;
            q = _filterRange switch
            {
                "ytd" => q.Where(t => t.OpenDate.Year == now.Year),
                "30d" => q.Where(t => t.OpenDate >= now.AddDays(-30)),
                "90d" => q.Where(t => t.OpenDate >= now.AddDays(-90)),
                "6m" => q.Where(t => t.OpenDate >= now.AddMonths(-6)),
                "1y" => q.Where(t => t.OpenDate >= now.AddYears(-1)),
                "custom" => q.Where(t =>
                    (_customStart == null || t.OpenDate >= _customStart.Value) &&
                    (_customEnd == null || t.OpenDate <= _customEnd.Value)),
                _ => q
            };
            if (_filterStatus != "all") q = q.Where(t => Status(t) == _filterStatus);
            if (_filterSymbol != "all") q = q.Where(t => t.Underlying == _filterSymbol);
            if (_filterSide != "all") q = q.Where(t => t.Right?.Trim().Equals(_filterSide, StringComparison.OrdinalIgnoreCase) == true);
            q = _filterReturn switch
            {
                "pos" => q.Where(t => t.ReturnGross > 0),
                "neg" => q.Where(t => t.ReturnGross < 0),
                "0-500" => q.Where(t => t.ReturnGross >= 0 && t.ReturnGross <= 500),
                "500-1000" => q.Where(t => t.ReturnGross > 500 && t.ReturnGross <= 1000),
                "1000+" => q.Where(t => t.ReturnGross > 1000),
                _ => q
            };
            return q.ToList();
        }
    }

    private decimal FilteredGrossReturn => FilteredTrades.Sum(t => t.ReturnGross);
    private decimal FilteredNetPL => FilteredTrades.Sum(t => t.NetPL);
    private decimal FilteredAvgPL => FilteredTrades.Count == 0 ? 0 : FilteredTrades.Average(t => t.NetPL);
    private int FilteredTradeCount => FilteredTrades.Count;

    private decimal FilteredWinRate
    {
        get
        {
            var closed = FilteredTrades.Where(t => t.CloseDate != null).ToList();
            if (closed.Count == 0) return 0;
            return (decimal)closed.Count(t => t.NetPL > 0) / closed.Count;
        }
    }

    private decimal FilteredProfitFactor
    {
        get
        {
            var closed = FilteredTrades.Where(t => t.CloseDate != null).ToList();
            var gains = closed.Where(t => t.NetPL > 0).Sum(t => t.NetPL);
            var losses = closed.Where(t => t.NetPL < 0).Sum(t => -t.NetPL);
            if (losses == 0) return gains > 0 ? 99m : 0m;
            return gains / losses;
        }
    }

    private decimal FilteredMaxDrawdown
    {
        get
        {
            var ordered = FilteredTrades.OrderBy(t => t.OpenDate).ToList();
            decimal peak = 0, drawdown = 0, cumulative = 0;
            foreach (var t in ordered)
            {
                cumulative += t.NetPL;
                if (cumulative > peak) peak = cumulative;
                var dd = peak - cumulative;
                if (dd > drawdown) drawdown = dd;
            }
            return drawdown;
        }
    }

    private double[] FilteredDonutWinLoss
    {
        get
        {
            var closed = FilteredTrades.Where(t => t.CloseDate != null).ToList();
            var wins = closed.Count(t => t.NetPL > 0);
            var losses = closed.Count(t => t.NetPL < 0);
            var total = Math.Max(wins + losses, 1);
            return new double[] { Math.Max(wins, 0.001), Math.Max(losses, 0.001) };
        }
    }

    private double[] FilteredSparkGross =>
        Cumulative(FilteredTrades.OrderBy(t => t.OpenDate).Select(t => (double)t.ReturnGross)).TakeLast(30).ToArray();

    private double[] FilteredSparkNetPl =>
        Cumulative(FilteredTrades.OrderBy(t => t.OpenDate).Select(t => (double)t.NetPL)).TakeLast(30).ToArray();

    private double[] FilteredSparkPf =>
        CumulativeProfitFactor(FilteredTrades.OrderBy(t => t.OpenDate).ToList()).TakeLast(30).ToArray();
}
