@using MudBlazor

<MudPaper Class="@RootClass" Elevation="1" Style="overflow:visible;">
    <div class="@AccentBarClass"></div>

    <div class="tl-kpi-inner">
        <div class="tl-kpi-left">
            <div class="tl-kpi-title">@Title</div>

            <MudText Class="tl-kpi-value">
                @Value
                @if (ShowTrend)
                {
                    <span class="tl-kpi-trend @(Trend > 0 ? "up" : Trend < 0 ? "down" : "flat")">
                        @(Trend > 0 ? "▲" : Trend < 0 ? "▼" : "—")
                    </span>
                }
            </MudText>

            @if (!string.IsNullOrWhiteSpace(Subtext))
            {
                <div class="tl-kpi-sub">@Subtext</div>
            }
        </div>

        <div class="tl-kpi-right">

            @* SVG Donut — no MudChart, no spinner *@
            @if (ShowDonut && DonutParts?.Length == 2)
            {
                var _total = DonutParts[0] + DonutParts[1];
                var _win = _total == 0 ? 0.5 : DonutParts[0] / _total;
                var _r = 20.0;
                var _cx = 28.0;
                var _cy = 28.0;
                var _circ = 2 * Math.PI * _r;
                var _winDash = _win * _circ;
                var _losDash = _circ - _winDash;
                var _inv = System.Globalization.CultureInfo.InvariantCulture;
                var _offset = (_circ * 0.25).ToString("0.##", _inv);
                var _winD = _winDash.ToString("0.##", _inv);
                var _losD = _losDash.ToString("0.##", _inv);
                var _cxS = _cx.ToString("0.##", _inv);
                var _cyS = _cy.ToString("0.##", _inv);
                var _rS = _r.ToString("0.##", _inv);
                var _lbl = $"{_win * 100:0}%";

                <div class="tl-kpi-viz tl-kpi-viz-donut">
                    <svg width="56" height="56" viewBox="0 0 56 56">
                        <circle cx="@_cxS" cy="@_cyS" r="@_rS"
                                fill="none" stroke="#f1f5f9" stroke-width="7" />
                        @if (_losDash > 0.5)
                        {
                            <circle cx="@_cxS" cy="@_cyS" r="@_rS"
                                    fill="none" stroke="#fca5a5" stroke-width="7"
                                    stroke-dasharray="@_losD @_winD"
                                    stroke-dashoffset="@_offset"
                                    stroke-linecap="round"
                                    transform="rotate(180 @_cxS @_cyS)" />
                        }
                        <circle cx="@_cxS" cy="@_cyS" r="@_rS"
                                fill="none" stroke="#22c55e" stroke-width="7"
                                stroke-dasharray="@_winD @_losD"
                                stroke-dashoffset="@_offset"
                                stroke-linecap="round" />
                        <text x="@_cxS" y="@_cyS"
                              text-anchor="middle"
                              dominant-baseline="middle"
                              font-size="9" font-weight="700"
                              fill="#0f172a">@_lbl</text>
                    </svg>
                </div>
            }

            @* Sparkline *@
            @if (ShowSparkline && Sparkline is not null && Sparkline.Length > 1)
            {
                <div class="tl-kpi-viz tl-kpi-viz-spark tl-kpi-spark-host">
                    <Sparkline Data="Sparkline"
                               Labels="SparkLabels"
                               WidthPx="104"
                               HeightPx="34"
                               StartColor="#6D28D9"
                               EndColor="#22C55E"
                               TooltipTitle="@Title"
                               SeriesLabel="@Title" />
                </div>
            }

        </div>
    </div>
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public string AccentClass { get; set; } = "accent-gray";
    [Parameter] public string Class { get; set; } = "";
    [Parameter] public string? Subtext { get; set; }
    [Parameter] public int Trend { get; set; } = 0;
    [Parameter] public bool ShowTrend { get; set; } = false;
    [Parameter] public string SparkSeriesLabel { get; set; } = "";

    [Parameter] public bool ShowDonut { get; set; }
    [Parameter] public double[]? DonutParts { get; set; }
    [Parameter] public string[] DonutLabels { get; set; } = Array.Empty<string>();

    [Parameter] public bool ShowSparkline { get; set; }
    [Parameter] public double[]? Sparkline { get; set; }
    [Parameter] public string[] SparkLabels { get; set; } = Array.Empty<string>();

    private string RootClass
    {
        get
        {
            var baseClass = string.IsNullOrWhiteSpace(Class)
                ? "tl-kpi-card"
                : $"tl-kpi-card {Class}";

            if (ShowDonut)
                baseClass += " has-donut";

            baseClass += Trend switch
            {
                > 0 => " trend-up",
                < 0 => " trend-down",
                _ => " trend-flat"
            };

            return baseClass;
        }
    }

    private string AccentBarClass =>
        string.IsNullOrWhiteSpace(AccentClass)
            ? "tl-kpi-accent"
            : $"tl-kpi-accent {AccentClass}";

    private double[] NormalizeForSparkline(double[] values)
    {
        if (values.Length == 0) return Array.Empty<double>();
        var min = values.Min();
        var max = values.Max();
        var range = max - min;
        if (range == 0) return values.Select(_ => 50d).ToArray();
        return values.Select(v => ((v - min) / range) * 100d).ToArray();
    }
}
